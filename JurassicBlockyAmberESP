local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Chờ thư mục xuất hiện trong Workspace để tránh lỗi khi map chưa load xong
local itemSpawn = Workspace:WaitForChild("ItemSpawn")
local amberFolder = itemSpawn:WaitForChild("Amber")

-- Bảng lưu trữ các UI đang hoạt động
local activeGuis = {}

-- Hàm tạo UI hiển thị khoảng cách
local function createBillboardGui(amberSpawn, model)
	-- Nếu đã có UI cho AmberSpawn này rồi thì bỏ qua
	if activeGuis[amberSpawn] then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "AmberTracker_" .. amberSpawn.Name
	billboard.Size = UDim2.new(0, 150, 0, 40)
	billboard.StudsOffset = Vector3.new(0, 4, 0) -- Nâng UI lên cao 1 chút để không bị lấp
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 1000 -- Khoảng cách tối đa (studs) để UI hiển thị

	-- Xác định vật thể để UI bám vào (Adornee)
	if amberSpawn:IsA("BasePart") then
		billboard.Adornee = amberSpawn
	elseif model:IsA("Model") and model.PrimaryPart then
		billboard.Adornee = model.PrimaryPart
	else
		-- Fallback: Nếu model không có PrimaryPart, bám vào part đầu tiên tìm thấy
		local firstPart = model:FindFirstChildWhichIsA("BasePart", true)
		if firstPart then
			billboard.Adornee = firstPart
		else
			billboard:Destroy()
			return
		end
	end

	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(1, 0, 1, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Font = Enum.Font.GothamBold -- Font chữ gọn gàng, hiện đại
	textLabel.TextScaled = true
	textLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Màu Neon Cyan
	textLabel.TextStrokeTransparency = 0.2 -- Viền đen để dễ đọc trên nền sáng
	textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	textLabel.Parent = billboard

	-- Đưa GUI vào PlayerGui (tối ưu cho LocalScript) thay vì vứt bừa vào Workspace
	billboard.Parent = playerGui
	activeGuis[amberSpawn] = billboard
end

-- Hàm xóa UI
local function removeBillboardGui(amberSpawn)
	if activeGuis[amberSpawn] then
		activeGuis[amberSpawn]:Destroy()
		activeGuis[amberSpawn] = nil
	end
end

-- Hàm kiểm tra xem bên trong AmberSpawn có Model nào không
local function checkAmberSpawn(amberSpawn)
	local model = amberSpawn:FindFirstChildOfClass("Model")
	if model then
		createBillboardGui(amberSpawn, model)
	else
		removeBillboardGui(amberSpawn)
	end
end

-- Thiết lập các sự kiện theo dõi cho một AmberSpawn cụ thể
local function setupAmberSpawn(amberSpawn)
	-- Kiểm tra ngay lần đầu tiên
	checkAmberSpawn(amberSpawn)

	-- Lắng nghe khi có một vật thể mới (đột nhiên xuất hiện)
	amberSpawn.ChildAdded:Connect(function(child)
		if child:IsA("Model") then
			checkAmberSpawn(amberSpawn)
		end
	end)

	-- Lắng nghe khi vật thể bị xóa mất
	amberSpawn.ChildRemoved:Connect(function(child)
		if child:IsA("Model") then
			checkAmberSpawn(amberSpawn)
		end
	end)
end

-- 1. Khởi tạo theo dõi cho các AmberSpawn CÓ SẴN từ trước
for _, spawnArea in ipairs(amberFolder:GetChildren()) do
	setupAmberSpawn(spawnArea)
end

-- 2. Lắng nghe nếu sau này game mới sinh ra thêm các AmberSpawn mới vào folder Amber
amberFolder.ChildAdded:Connect(setupAmberSpawn)

-- 3. Vòng lặp cập nhật khoảng cách liên tục (mỗi frame)
RunService.RenderStepped:Connect(function()
	local character = player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")

	if not rootPart then return end

	-- Quét qua tất cả các UI đang bật và tính toán lại con số
	for amberSpawn, gui in pairs(activeGuis) do
		local adornee = gui.Adornee
		if adornee then
			local distance = math.floor((rootPart.Position - adornee.Position).Magnitude)
			gui.TextLabel.Text = string.format("Amber (%dm)", distance)
		end
	end
end)
