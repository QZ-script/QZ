---------------------------------------------------------
-- 2. HÀM XỬ LÝ KÉO PANEL (DRAGGING)
---------------------------------------------------------
local dragging, dragInput, dragStart, startPos

local function update(input)
	local delta = input.Position - dragStart
	mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

mainFrame.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		update(input)
	end
end)

---------------------------------------------------------
-- 3. LOGIC ESP (TRACKING)
---------------------------------------------------------

local function createBillboardGui(amberSpawn, model)
	if activeGuis[amberSpawn] then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "AmberTracker"
	billboard.Size = UDim2.new(0, 150, 0, 40)
	billboard.StudsOffset = Vector3.new(0, 4, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 1000
	billboard.Enabled = espEnabled -- Trạng thái dựa trên biến điều khiển

	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(1, 0, 1, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Font = Enum.Font.GothamBold
	textLabel.TextScaled = true
	textLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
	textLabel.TextStrokeTransparency = 0.5
	textLabel.Text = "Amber (calculating...)" -- Hiện text tạm thay vì "Label"
	textLabel.Parent = billboard

	-- Gắn vào Model hoặc Part
	billboard.Adornee = amberSpawn:IsA("BasePart") and amberSpawn or model:FindFirstChildWhichIsA("BasePart", true)
	billboard.Parent = playerGui
	activeGuis[amberSpawn] = billboard
end

local function removeBillboardGui(amberSpawn)
	if activeGuis[amberSpawn] then
		activeGuis[amberSpawn]:Destroy()
		activeGuis[amberSpawn] = nil
	end
end

local function checkAmberSpawn(amberSpawn)
	local model = amberSpawn:FindFirstChildOfClass("Model")
	if model then
		createBillboardGui(amberSpawn, model)
	else
		removeBillboardGui(amberSpawn)
	end
end

-- Theo dõi sự kiện thêm/bớt Model
local function setupAmberSpawn(amberSpawn)
	checkAmberSpawn(amberSpawn)
	amberSpawn.ChildAdded:Connect(function(child)
		if child:IsA("Model") then checkAmberSpawn(amberSpawn) end
	end)
	amberSpawn.ChildRemoved:Connect(function(child)
		if child:IsA("Model") then checkAmberSpawn(amberSpawn) end
	end)
end

-- Khởi tạo ban đầu
for _, spawnArea in ipairs(amberFolder:GetChildren()) do
	setupAmberSpawn(spawnArea)
end
amberFolder.ChildAdded:Connect(setupAmberSpawn)

-- Nút Bật/Tắt ESP
toggleBtn.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	toggleBtn.Text = espEnabled and "ESP: ON" or "ESP: OFF"
	toggleBtn.TextColor3 = espEnabled and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(255, 100, 100)
	
	-- Cập nhật ngay lập tức các GUI đang hiện
	for _, gui in pairs(activeGuis) do
		gui.Enabled = espEnabled
	end
end)

-- Vòng lặp cập nhật khoảng cách
RunService.RenderStepped:Connect(function()
	if not espEnabled then return end -- Tiết kiệm hiệu năng nếu tắt ESP

	local character = player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	for amberSpawn, gui in pairs(activeGuis) do
		local adornee = gui.Adornee
		if adornee then
			local distance = math.floor((rootPart.Position - adornee.Position).Magnitude)
			gui.TextLabel.Text = "Amber (" .. distance .. "m)"
		end
	end
end)
