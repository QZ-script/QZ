--------------------------------------------------
-- COLLAPSE / EXPAND (SMOOTH)
--------------------------------------------------
local function tweenMenu(collapse)
	isCollapsed = collapse
	collapseBtn.Text = collapse and "+" or "–"

	local info = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	TweenService:Create(main, info, {
		Size = collapse and collapsedSize or expandedSize
	}):Play()

	for _,v in ipairs(main:GetChildren()) do
		if v:IsA("TextButton") and v ~= collapseBtn then
			TweenService:Create(v, info, {
				BackgroundTransparency = collapse and 1 or 0,
				TextTransparency = collapse and 1 or 0
			}):Play()
		end
	end
end

collapseBtn.MouseButton1Click:Connect(function()
	tweenMenu(not isCollapsed)
end)

local function getScale(distance)
	return math.clamp(1 / (distance / 35), 0.6, 1.6)
end

-- ESP GUI
local function createESP(player)
	if espGuis[player] then return end
	if teammateCheck and player.Team == LocalPlayer.Team then return end

	local char = player.Character
	if not char then return end

	local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
	if not root then return end

	local bb = Instance.new("BillboardGui")
	bb.Name = "SimpleESP"
	bb.Adornee = root
	bb.AlwaysOnTop = true
	bb.StudsOffset = Vector3.new(0, 3, 0)
	bb.Size = UDim2.fromOffset(80, 40)
	bb.Parent = LocalPlayer:WaitForChild("PlayerGui")

	local text = Instance.new("TextLabel")
	text.Size = UDim2.fromScale(1,1)
	text.BackgroundTransparency = 1
	text.TextColor3 = Color3.fromRGB(255,255,255)
	text.TextStrokeTransparency = 0
	text.TextStrokeColor3 = Color3.new(0,0,0)
	text.Font = Enum.Font.GothamBold
	text.TextSize = 14
	text.TextWrapped = true
	text.TextYAlignment = Enum.TextYAlignment.Center
	text.Parent = bb

	espGuis[player] = {
		gui = bb,
		label = text
	}
end

local function removeESP(player)
	if espGuis[player] then
		espGuis[player].gui:Destroy()
		espGuis[player] = nil
	end
end

RunService.RenderStepped:Connect(function()
	for plr, data in pairs(espGuis) do
		local char = plr.Character
		if not char then
			-- character chưa replicate → CHỜ
			continue
		end

		local hum = char:FindFirstChildOfClass("Humanoid")
		local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")

		if hum and hum.Health <= 0 then
			-- chết thật → remove
			removeESP(plr)
			continue
		end

		if not root then
			-- root chưa load → CHỜ
			continue
		end

		data.gui.Adornee = root
		data.label.Text = plr.Name .. "\n" .. math.floor(hum.Health)

		local dist = (Camera.CFrame.Position - root.Position).Magnitude
		local scale = math.clamp(40 / dist, 0.6, 1.8)

		data.gui.Size = UDim2.fromOffset(80 * scale, 40 * scale)
		data.label.TextSize = 14 * scale
	end
end)

local function hookPlayer(player)
	-- nếu ESP đang bật và character đã tồn tại
	if espEnabled and player.Character then
		createESP(player)
	end

	player.CharacterAdded:Connect(function(char)
		if not espEnabled then return end

		local hum = char:WaitForChild("Humanoid", 5)
		local root = char:WaitForChild("HumanoidRootPart", 5)
		if hum and root then
			removeESP(player)
			createESP(player)
		end
	end)
end


for _,plr in ipairs(Players:GetPlayers()) do
	if plr ~= LocalPlayer then
		hookPlayer(plr)
	end
end

Players.PlayerAdded:Connect(function(plr)
	if plr ~= LocalPlayer then
		hookPlayer(plr)
	end
end)
Players.PlayerRemoving:Connect(removeESP)

local function refreshESP()
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			if espEnabled then
				createESP(plr)
			else
				removeESP(plr)
			end
		end
	end
end

