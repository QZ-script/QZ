local function updateAimUI()
	if aiming then
		aimBtn.Text = "AIM : ON (B)"
		aimBtn.BackgroundColor3 = Color3.fromRGB(60,200,60)
		startAim()
	else
		aimBtn.Text = "AIM : OFF (B)"
		aimBtn.BackgroundColor3 = Color3.fromRGB(200,50,50)
		stopAim()
	end
end

local function updateTeamUI()
	teamBtn.Text = teammateCheck and "TEAMMATE CHECK : ON" or "TEAMMATE CHECK : OFF"
	teamBtn.BackgroundColor3 = teammateCheck and Color3.fromRGB(60,200,60) or Color3.fromRGB(200,50,50)
	refreshESP()
end

local function updateESPUI()
	espBtn.Text = espEnabled and "ESP : ON" or "ESP : OFF"
	espBtn.BackgroundColor3 = espEnabled and Color3.fromRGB(60,200,60) or Color3.fromRGB(200,50,50)
	refreshESP()
end

