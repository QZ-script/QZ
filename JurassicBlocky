-- MINIMIZE/CLOSE BUTTONS LOGIC
---------------------------------------------------------
-- Đã chuyển sang dạng Offset hoàn toàn
local normalSize = UDim2.new(0, 250, 0, 175) 
local minimizedSize = UDim2.new(0, 250, 0, 35) -- Khi thu gọn chỉ cao 35px
local normalTitlePos = UDim2.new(0, 125, 0, 17)
local minimizedTitlePos = UDim2.new(0, 125, 0, 17) -- Giữ nguyên vị trí chữ khi thu gọn
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function toggleMinimize()
	isMinimized = not isMinimized
	
	if isMinimized then
		-- Minimize
		local tween = tweenService:Create(mainFrame, tweenInfo, {Size = minimizedSize})
		tween:Play()
		
		local titleTween = tweenService:Create(title, tweenInfo, {Position = minimizedTitlePos})
		titleTween:Play()
		
		minimizeBtn.Text = "+"
		
		toggleBtn.Visible = false
		speedToggleBtn.Visible = false
		ultraSpeedBtn.Visible = false
	else
		-- Expand
		local tween = tweenService:Create(mainFrame, tweenInfo, {Size = normalSize})
		tween:Play()
		
		local titleTween = tweenService:Create(title, tweenInfo, {Position = normalTitlePos})
		titleTween:Play()
		
		minimizeBtn.Text = "-"
		
		toggleBtn.Visible = true
		speedToggleBtn.Visible = true
		ultraSpeedBtn.Visible = true
	end
end

minimizeBtn.MouseButton1Click:Connect(toggleMinimize)

closeBtn.MouseButton1Click:Connect(function()
	screenGui:Destroy()
end)

